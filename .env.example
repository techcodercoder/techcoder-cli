# TechCoder CLI — environment variables
# Copy to .env and fill in your values (never commit .env)

# Ollama model to use (default: gemma4:e4b)
TECHCODER_MODEL=gemma4:e4b

# Web UI port (default: 3000)
TECHCODER_PORT=3000

# Log level: DEBUG | INFO | WARNING | ERROR
TECHCODER_LOG_LEVEL=INFO

# GitHub personal access token (for MCP GitHub server)
GITHUB_TOKEN=
